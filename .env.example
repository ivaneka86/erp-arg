# Salin file ini jadi .env untuk development lokal (JANGAN commit file .env ke git)

# Connection string dari Neon (Settings > Connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# String acak panjang untuk JWT — generate sendiri, JANGAN pakai contoh ini
# Contoh generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_dengan_string_acak_panjang_minimal_32_karakter

# Password untuk user awal (hanya dipakai SEKALI saat tabel users masih kosong)
ADMIN_PASSWORD=ganti_password_admin_yang_kuat
IVANEKA_PASSWORD=ganti_password_ivaneka_yang_kuat

# Port (opsional, Render akan override otomatis)
PORT=3000
